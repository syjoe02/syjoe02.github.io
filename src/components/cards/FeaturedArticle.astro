---
interface Props {
	title: string;
	href: string;
	description: string;
	tags?: string[];
	readingTime?: string;
	eyebrow?: string;
	gradient?: string;
}

const {
	title,
	href,
	description,
	tags = [],
	readingTime,
	eyebrow = 'Featured',
	gradient = 'ec-gradient-default',
} = Astro.props;
---

<a href={href} class="ec-featured-card">
	<div class={`ec-featured-cover ${gradient}`}></div>
	<div class="ec-featured-body">
		<span class="ec-featured-eyebrow">{eyebrow}</span>
		<h2 class="ec-featured-title">{title}</h2>
		<p class="ec-featured-desc">{description}</p>
		{tags.length > 0 && (
			<div class="ec-card-tags">
				{tags.map((tag) => <span class="ec-tag">{tag}</span>)}
			</div>
		)}
		<div class="ec-featured-footer">
			<span class="ec-featured-link">
				Read article
				<svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
					<path d="M3 7h8M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.5"
						stroke-linecap="round" stroke-linejoin="round"/>
				</svg>
			</span>
			{readingTime && <span class="ec-card-reading-time">{readingTime}</span>}
		</div>
	</div>
</a>
